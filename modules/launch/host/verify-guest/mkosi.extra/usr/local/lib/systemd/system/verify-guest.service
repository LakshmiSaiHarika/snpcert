[Unit]
Description=Verify the SEV-SNP guest booted correctly
DefaultDependencies=no
After=launch-guest.service
Wants=launch-guest.service

[Service]
Type=oneshot
ExecStart=/usr/local/lib/scripts/verify-guest.sh
StandardOutput=journal+console
StandardError=journal+console
LogExtraFields="SEV_VERSION=3.0.0-0" "SNPHOST_TEST=3.0.0-0"
